{
  "expo": {
    "name": "ClassMatePro",
    "slug": "ClassMatePro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ClassMatePro.png",
    "scheme": "classmatepro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.samim123ali.classmatepro",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ClassMatePro.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ClassMatePro.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ClassMatePro.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "00282633-73eb-4b0f-8959-1136e519e673"
      }
    },
    "owner": "samim123ali"
  }
}
